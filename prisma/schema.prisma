// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SECRETARY
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  NO_SHOW
}

enum TreatmentType {
  BASIC
  UPSELL
  CROSS_SELL
  BUNDLE
}

enum PatientEventType {
  SMS_OPENED
  LINK_CLICKED
  APPOINTMENT_CONFIRMED
  NO_SHOW
  APPOINTMENT_CANCELLED
  REMINDER_SENT
}

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum MessageQueueStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum TreatmentRecommendationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Clinic {
  id           String         @id @default(cuid())
  name         String
  planType     String
  createdAt    DateTime       @default(now())
  users        User[]
  patients     Patient[]
  appointments Appointment[]
}

model User {
  id       String   @id @default(cuid())
  email    String
  role     UserRole
  clinicId String
  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, email])
}

model Patient {
  id                      String                   @id @default(cuid())
  firstName               String
  lastName                String
  phone                   String
  ltv                     Float                    @default(0)
  noShowScore             Float                    @default(0)
  totalSessions           Int                      @default(0)
  totalTreatments         Int                      @default(0)
  clinicId                String
  clinic                  Clinic                   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments            Appointment[]
  patientEvents           PatientEvent[]
  messageQueues           MessageQueue[]
  treatmentRecommendations TreatmentRecommendation[]
}

model Appointment {
  id            String         @id @default(cuid())
  date          DateTime
  status        AppointmentStatus
  patientId     String
  clinicId      String
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  treatments    Treatment[]
  messageQueues MessageQueue[]
}

model Treatment {
  id            String        @id @default(cuid())
  name          String
  type          TreatmentType
  price         Float
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model PatientEvent {
  id        String           @id @default(cuid())
  patientId String
  eventType PatientEventType
  metadata  Json?
  createdAt DateTime         @default(now())
  patient   Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MessageQueue {
  id             String             @id @default(cuid())
  patientId      String
  appointmentId  String?
  channel        MessageChannel
  templateId     String
  scheduledAt    DateTime
  status         MessageQueueStatus
  sentAt         DateTime?
  responseText   String?
  createdAt      DateTime           @default(now())
  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment    Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}

model TreatmentRecommendation {
  id                   String                       @id @default(cuid())
  patientId            String
  recommendedTreatment String
  triggerTreatment     String
  ruleId               String
  priorityScore        Int
  status               TreatmentRecommendationStatus
  createdAt            DateTime                     @default(now())
  patient              Patient                      @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
